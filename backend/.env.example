# ─── App ───────────────────────────────────────────────
APP_NAME=Nexus Agents
# CHANGE THIS in production — used to sign auth tokens
SECRET_KEY=dev-insecure-change-me
DATABASE_URL=sqlite:///./agent_platform.db
TOKEN_TTL_HOURS=168

# ─── LLM provider ──────────────────────────────────────
# auto | anthropic | openai | demo
# "auto" picks anthropic if ANTHROPIC_API_KEY is set, else openai, else demo.
# "demo" works fully offline (no API key) so you can try the platform immediately.
LLM_PROVIDER=auto

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Any OpenAI-compatible endpoint works (OpenAI, OpenRouter, local llama.cpp, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

LLM_MAX_TOKENS=600

# ─── Channels (optional, can also be set per-channel in the UI) ───
# Avito — https://developers.avito.ru
AVITO_API_BASE=https://api.avito.ru
